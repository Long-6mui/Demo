<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- HEADER -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="50dp">

            <ImageButton
                android:id="@+id/btnBackFeedback"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/circle_white_bg"
                android:src="@drawable/ic_arrow_back"
                android:padding="10dp"/>

        </RelativeLayout>

        <!-- TEXT GIỚI THIỆU -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Chúng tôi rất vui nếu được nghe góp ý của bạn cho các kết quả tìm kiếm. Xin gửi chúng tôi góp ý của bạn để ứng dụng có thể cải thiện tốt hơn. Nếu bạn cần hỗ trợ từ đội ngũ, vui lòng liên hệ qua email."
            android:textSize="16sp"
            android:textColor="#333333"
            android:lineSpacingExtra="4dp"
            android:layout_marginTop="10dp"/>

        <!-- Ô GÓP Ý -->
        <EditText
            android:id="@+id/edtFeedback"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_feedback_box"
            android:hint="Viết góp ý của bạn ở đây..."
            android:textSize="16sp"
            android:gravity="top"
            android:padding="16dp"/>

        <!-- TEXT CUỐI -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Chúng tôi sẽ sử dụng thông tin này để hoàn thiện công cụ tìm kiếm. Khi góp ý này được gửi đi, bạn đã đồng ý để chúng tôi sử dụng thông tin đó theo Chính Sách Bảo Mật và Điều Khoản Dịch Vụ của công ty."
            android:textSize="15sp"
            android:textColor="#333333"
            android:lineSpacingExtra="4dp"/>

        <!-- BUTTON -->
        <Button
            android:id="@+id/btnSendFeedback"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Gửi góp ý"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1A3A2A"
            android:layout_marginTop="25dp"/>

    </LinearLayout>

</ScrollView>