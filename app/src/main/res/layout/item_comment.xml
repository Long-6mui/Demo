<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp"
    android:background="@drawable/bg_comment_item">   <!-- Có thể thêm background bo góc nếu muốn -->

    <!-- Avatar -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardAvatar"
        android:layout_width="40dp"
        android:layout_height="40dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="2dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/imgAvatar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/avtque"
            android:contentDescription="Avatar"/>
    </androidx.cardview.widget.CardView>

    <!-- Username + Thời gian (nếu có) -->
    <TextView
        android:id="@+id/txtUser"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textStyle="bold"
        android:textSize="14sp"
        android:textColor="@color/colorPrimaryDark"
        android:ellipsize="end"
        android:maxLines="1"
        app:layout_constraintStart_toEndOf="@id/cardAvatar"
        app:layout_constraintEnd_toStartOf="@id/btnMenuComment"
        app:layout_constraintTop_toTopOf="@id/cardAvatar"
        android:layout_marginStart="12dp"/>

    <!-- Nút menu (3 chấm) -->
    <ImageButton
        android:id="@+id/btnMenuComment"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_more"
        app:layout_constraintTop_toTopOf="@id/cardAvatar"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Nội dung comment -->
    <TextView
        android:id="@+id/txtContent"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="#212121"
        android:lineSpacingExtra="4dp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/cardAvatar"
        app:layout_constraintStart_toStartOf="@id/cardAvatar"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Ảnh trong comment (nếu có) -->
    <ImageView
        android:id="@+id/imgComment"
        android:layout_width="0dp"
        android:layout_height="180dp"
        android:scaleType="centerCrop"
        android:background="@drawable/bg_image_radius"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/txtContent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:visibility="gone"
        android:contentDescription="Comment image"/>

</androidx.constraintlayout.widget.ConstraintLayout>